# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/novum

# ============================================================================
# LLM — V1 active provider: Anthropic Claude only (ai-services.md §1.2 / §1.3)
# Interface (litellm) supports github | openai | anthropic | google.
# To re-enable cross-family providers (Plan-B / outage), set:
#   ALLOW_NON_ANTHROPIC_PROVIDERS=true
#   LLM_PROVIDER=<provider>
# ============================================================================
LLM_PROVIDER=anthropic
JUDGE_PROVIDER=anthropic
ALLOW_NON_ANTHROPIC_PROVIDERS=false

# Anthropic Claude — V1 active provider (REQUIRED)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
# Per-role model assignment (ai-services.md §1.3)
ANTHROPIC_MODEL=anthropic/claude-sonnet-4-6
ANTHROPIC_MODEL_CLASSIFIER=anthropic/claude-haiku-4-5
ANTHROPIC_MODEL_PLANNER=anthropic/claude-sonnet-4-6
ANTHROPIC_MODEL_SYNTHESIZER=anthropic/claude-sonnet-4-6
ANTHROPIC_MODEL_JUDGE=anthropic/claude-sonnet-4-6

# ============================================================================
# Wired-but-disabled fallback providers (optional in V1 — Plan-B only)
# ============================================================================

# GitHub Models
GITHUB_TOKEN=
GITHUB_TOKENS=

# OpenAI direct (also used by saturation embeddings if enabled)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4

# Google Gemini
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini/gemini-2.5-flash

# Search
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxx

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false

# CORS: comma-separated list of allowed frontend origins
CORS_ORIGINS=https://novum-seven.vercel.app,http://localhost:5173

# ============================================================================
# Meta-judge (BRD-26 / IP-26 / PR-2). Enabled by default. Set to false
# to revert to the legacy behaviour where only hard caps stop the run.
# ============================================================================
META_JUDGE_ENABLED=true
META_JUDGE_BEFORE_SYNTH_MIN_EVIDENCE=20
