# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/novum

# LLM provider selector — github | openai | anthropic | google
LLM_PROVIDER=github

# GitHub Models (default provider)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
# Optional: comma-separated pool of PATs for per-call rotation
GITHUB_TOKENS=

# OpenAI (active when LLM_PROVIDER=openai; also used for embeddings)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4

# Anthropic Claude (active when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=anthropic/claude-sonnet-4-6

# Google Gemini (active when LLM_PROVIDER=google)
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini/gemini-2.5-flash

# Search
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxx

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false

# CORS: comma-separated list of allowed frontend origins
CORS_ORIGINS=https://novum-seven.vercel.app,http://localhost:5173
